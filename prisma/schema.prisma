generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id              String           @id @db.Uuid
  displayName     String?          @map("display_name") @db.VarChar(100)
  theme           String           @default("light") @db.VarChar(10)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  projects        Project[]
  writingSessions WritingSession[]
  @@map("profiles")
}

model Project {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String   @db.VarChar(200)
  description String?  @db.Text
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  user        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  atoms       Atom[]
  clusters    Cluster[]
  drafts      Draft[]
  @@index([userId])
  @@index([updatedAt(sort: Desc)])
  @@map("projects")
}

model Atom {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  content    String   @db.Text
  clusterId  String?  @map("cluster_id") @db.Uuid
  position   Int      @default(0)
  isArchived Boolean  @default(false) @map("is_archived")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  cluster    Cluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  @@index([projectId])
  @@index([clusterId])
  @@map("atoms")
}

model Cluster {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  title     String   @db.VarChar(100)
  position  Int      @default(0)
  color     String?  @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  atoms     Atom[]
  @@index([projectId])
  @@map("clusters")
}

model Draft {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  content   Json     @default("{}")
  wordCount Int      @default(0) @map("word_count")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots Snapshot[]
  @@index([projectId])
  @@map("drafts")
}

model Snapshot {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  draftId   String   @map("draft_id") @db.Uuid
  content   Json
  wordCount Int      @default(0) @map("word_count")
  label     String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  draft     Draft    @relation(fields: [draftId], references: [id], onDelete: Cascade)
  @@index([draftId])
  @@map("snapshots")
}

model WritingSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  date      DateTime @map("date") @db.Date
  wordCount Int      @default(0) @map("word_count")
  duration  Int      @default(0) // seconds
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  user      Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("writing_sessions")
}